# Copy to `.env` and replace placeholder values before running locally.
# `docker compose` will read this file automatically from the backend repo root.

POSTGRES_DB=appdist
POSTGRES_USER=appdist
POSTGRES_PASSWORD=SET_POSTGRES_PASSWORD

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=SET_MINIO_ROOT_PASSWORD

DATABASE_URL=jdbc:postgresql://postgres:5432/appdist

MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=SET_MINIO_SECRET_KEY
MINIO_BUCKET=appdist-builds

JWT_SECRET=SET_JWT_SECRET_MIN_32_CHARS
JWT_ISSUER=app-distribution
JWT_AUDIENCE=app-distribution-clients
